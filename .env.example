# Chasqui web channel gateway (ADR-011)

# Port this gateway listens on.
PORT=8002

# The core's base URL — where /ingest and the internal history read live.
CORE_URL=http://localhost:8090

# Shared secret with the core (must equal the core's INTERNAL_API_KEY).
# Unset = open (LOCAL DEV ONLY). Lives only here on the server, never in the browser.
# INTERNAL_API_KEY=

# Comma-separated origins allowed to embed the widget (the customers' sites).
# '*' = any (DEV ONLY — never in production).
WEB_ALLOWED_ORIGINS=http://localhost:8002

# Public rate limit, per visitor/IP.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# How many past messages to rehydrate when the widget (re)opens.
HISTORY_LIMIT=50

# Gateway-local, user-facing literals (English default) — shown only when the
# CORE is unreachable, so they must live here, not in the core.
ERROR_REPLY=Sorry, something went wrong. Please try again in a moment.
UNSUPPORTED_REPLY=Sorry, I can't handle that kind of message here.

# NOTE: the CORE must set CHANNEL_WEB_SEND_URL=<this gateway>/send so the core's
# deferred replies (ADR-008) reach the browser over SSE.
